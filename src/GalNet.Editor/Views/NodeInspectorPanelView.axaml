<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:GalNet.Editor.Controls"
             xmlns:vm="using:GalNet.Editor.ViewModels"
             x:Class="GalNet.Editor.Views.NodeInspectorPanelView"
             x:Name="Root"
             x:DataType="vm:NodeInspectorPanelViewModel"
             Background="{DynamicResource SemiColorBackground0}">
    <ScrollViewer>
        <StackPanel Margin="12" Spacing="10">
            <TextBlock Text="Inspector"
                       FontSize="16"
                       FontWeight="SemiBold" />

            <StackPanel Spacing="8"
                        IsVisible="{Binding IsPreviewVariablesVisible}">
                <Expander Header="Player Variables"
                          IsExpanded="True">
                    <controls:VariableListEditorControl DataContext="{Binding Workspace.ActivePreview.PlayerVariables}" />
                </Expander>
                <Expander Header="Save Variables"
                          IsExpanded="True">
                    <controls:VariableListEditorControl DataContext="{Binding Workspace.ActivePreview.SaveVariables}" />
                </Expander>
            </StackPanel>

            <StackPanel Spacing="8"
                        IsVisible="{Binding IsNodeInspectorVisible}">
                <TextBlock Text="No node selected"
                           Foreground="{DynamicResource SemiColorText2}"
                           IsVisible="{Binding !HasSelectedNode}" />

                <StackPanel Spacing="8"
                            IsVisible="{Binding HasSelectedNode}">
                    <TextBlock Text="Name" />
                    <TextBox Text="{Binding Workspace.SelectedNode.Name}" />

                    <TextBlock Text="Type" />
                    <Border Background="{DynamicResource SemiColorFill0}"
                            BorderBrush="{DynamicResource SemiColorBorder}"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="8,5">
                        <TextBlock Text="{Binding Workspace.SelectedNode.KindLabel}"
                                   Foreground="{DynamicResource SemiColorText1}"
                                   TextTrimming="CharacterEllipsis" />
                    </Border>

                    <TextBlock Text="Id" />
                    <Border Background="{DynamicResource SemiColorFill0}"
                            BorderBrush="{DynamicResource SemiColorBorder}"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="8,5">
                        <TextBlock Text="{Binding Workspace.SelectedNode.Id}"
                                   FontFamily="Consolas"
                                   FontSize="12"
                                   Foreground="{DynamicResource SemiColorText2}"
                                   TextTrimming="CharacterEllipsis" />
                    </Border>

                    <StackPanel Spacing="6"
                                IsVisible="{Binding IsLinearGroupSelected}">
                        <TextBlock Text="Linear Group"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="{Binding Workspace.SelectedNode.EntryCount, StringFormat='Entries: {0}'}"
                                   Foreground="{DynamicResource SemiColorText2}" />
                        <Button Content="Open Group Editor"
                                HorizontalAlignment="Left"
                                Command="{Binding OpenGroupEditorCommand}" />
                    </StackPanel>

                    <StackPanel Spacing="6"
                                IsVisible="{Binding IsChoiceBranchSelected}">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Text="Options"
                                       FontWeight="SemiBold" />
                            <Button Grid.Column="1"
                                    Content="Add"
                                    Command="{Binding Workspace.AddChoiceOptionCommand}" />
                        </Grid>
                        <ListBox Name="OptionsListBox"
                                 ItemsSource="{Binding Workspace.SelectedNode.Options}"
                                 Background="Transparent">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="vm:BranchOptionEditorItemViewModel">
                                    <Border Margin="0,4"
                                            Padding="8"
                                            Background="{DynamicResource SemiColorBackground1}"
                                            BorderBrush="{DynamicResource SemiColorBorder}"
                                            BorderThickness="1"
                                            CornerRadius="6">
                                        <Grid ColumnDefinitions="Auto,*,*,Auto"
                                              ColumnSpacing="6">
                                            <Border Padding="6,0"
                                                    Background="Transparent"
                                                    Cursor="SizeAll"
                                                    PointerPressed="OnChoiceOptionDragPointerPressed">
                                                <TextBlock Text="::" />
                                            </Border>
                                            <TextBox Grid.Column="1"
                                                     Text="{Binding Text}" />
                                            <controls:ConditionEditorControl Grid.Column="2"
                                                                             Text="{Binding Condition}"
                                                                             Suggestions="{Binding #Root.DataContext.ConditionSuggestions}"
                                                                             ValidationVariables="{Binding #Root.DataContext.ValidationVariables}" />
                                            <Button Grid.Column="3"
                                                    Content="Remove"
                                                    Command="{Binding #Root.DataContext.Workspace.RemoveChoiceOptionCommand}"
                                                    CommandParameter="{Binding}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>

                    <StackPanel Spacing="6"
                                IsVisible="{Binding IsConditionBranchSelected}">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Text="Conditions"
                                       FontWeight="SemiBold" />
                            <Button Grid.Column="1"
                                    Content="Add"
                                    Command="{Binding Workspace.AddConditionCommand}" />
                        </Grid>
                        <ListBox Name="ConditionsListBox"
                                 ItemsSource="{Binding Workspace.SelectedNode.Conditions}"
                                 Background="Transparent">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="vm:BranchConditionEditorItemViewModel">
                                    <Border Margin="0,4"
                                            Padding="8"
                                            Background="{DynamicResource SemiColorBackground1}"
                                            BorderBrush="{DynamicResource SemiColorBorder}"
                                            BorderThickness="1"
                                            CornerRadius="6">
                                        <Grid ColumnDefinitions="Auto,*,Auto"
                                              ColumnSpacing="6">
                                            <Border Padding="6,0"
                                                    Background="Transparent"
                                                    Cursor="SizeAll"
                                                    PointerPressed="OnConditionDragPointerPressed">
                                                <TextBlock Text="::" />
                                            </Border>
                                            <controls:ConditionEditorControl Grid.Column="1"
                                                                             Text="{Binding Expression}"
                                                                             Suggestions="{Binding #Root.DataContext.ConditionSuggestions}"
                                                                             ValidationVariables="{Binding #Root.DataContext.ValidationVariables}" />
                                            <Button Grid.Column="2"
                                                    Content="Remove"
                                                    Command="{Binding #Root.DataContext.Workspace.RemoveConditionCommand}"
                                                    CommandParameter="{Binding}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
