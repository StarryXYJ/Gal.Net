<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:GalNet.Editor.ViewModels"
             xmlns:loc="clr-namespace:GalNet.Editor.MarkupExtensions"
             x:Class="GalNet.Editor.Views.NewProjectPanelView"
             x:DataType="vm:NewProjectPanelViewModel"
             Background="{DynamicResource SemiColorBackground0}">
    <ScrollViewer>
        <StackPanel Margin="12" Spacing="10" MaxWidth="520">
            <TextBlock Text="New Project"
                       FontSize="16"
                       FontWeight="SemiBold" />

            <TextBlock Text="Name" />
            <TextBox Text="{Binding ProjectName}" />

            <TextBlock Text="Parent Folder" />
            <TextBox Text="{Binding ProjectRoot}" />

            <TextBlock Text="Design Resolution" />
            <ComboBox ItemsSource="{Binding ResolutionPresets}"
                      Text="{Binding Resolution}"
                      IsEditable="True" />

            <TextBlock Text="{loc:Localize NewProject.ColorPalette}" />
            <ComboBox ItemsSource="{Binding ColorPalettes}"
                      SelectedValue="{Binding SelectedColorPaletteId}"
                      SelectedValueBinding="{Binding Id}">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Border Width="16" Height="16" CornerRadius="8">
                                <Border.Background><SolidColorBrush Color="{Binding PreviewColor}" /></Border.Background>
                            </Border>
                            <TextBlock Text="{loc:Localize DisplayNameKey}" VerticalAlignment="Center" />
                        </StackPanel>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="Create Project"
                        Command="{Binding CreateCommand}" />
                <Button Content="Cancel"
                        Command="{Binding CancelCommand}" />
            </StackPanel>

            <TextBlock Text="{Binding Message}"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource SemiColorText2}" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
