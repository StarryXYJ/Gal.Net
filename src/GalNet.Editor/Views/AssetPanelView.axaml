<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:GalNet.Editor.ViewModels"
             xmlns:model="using:GalNet.Editor.Models"
             x:Class="GalNet.Editor.Views.AssetPanelView"
             x:Name="Root"
             x:DataType="vm:AssetPanelViewModel"
             Background="{DynamicResource SemiColorBackground0}">
  <Grid RowDefinitions="Auto,*,Auto">
    <StackPanel Orientation="Horizontal" Spacing="8" Margin="4">
      <Button Content="←" Command="{Binding BackCommand}" IsEnabled="{Binding CanGoBack}" ToolTip.Tip="Back"/>
      <TextBox Width="280" Text="{Binding PathText}" LostFocus="OnPathLostFocus" KeyDown="OnPathKeyDown" />
    </StackPanel>
    <ListBox Grid.Row="1" ItemsSource="{Binding Entries}" SelectedItem="{Binding SelectedEntry}" Margin="4">
      <ListBox.ItemsPanel><ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate></ListBox.ItemsPanel>
      <ListBox.ItemTemplate>
        <DataTemplate x:DataType="model:AssetEntry">
          <Border Width="116" Height="128" Padding="6" Margin="3" DoubleTapped="OnEntryDoubleTapped">
            <Border.ContextMenu>
              <ContextMenu>
                <MenuItem Header="Open" Command="{Binding #Root.DataContext.OpenCommand}" CommandParameter="{Binding}" />
                <MenuItem Header="Show in Explorer" Command="{Binding #Root.DataContext.ShowInExplorerCommand}" CommandParameter="{Binding}" />
                <Separator />
                <MenuItem Header="Copy" Command="{Binding #Root.DataContext.CopySelectedCommand}" />
                <MenuItem Header="Cut" Command="{Binding #Root.DataContext.CutSelectedCommand}" />
                <MenuItem Header="Paste" Command="{Binding #Root.DataContext.PasteCommand}" />
                <Separator />
                <MenuItem Header="Delete" Command="{Binding #Root.DataContext.DeleteSelectedCommand}" />
              </ContextMenu>
            </Border.ContextMenu>
            <StackPanel Spacing="4">
              <Border Height="88" Background="{DynamicResource SemiColorFill0}" CornerRadius="4">
                <TextBlock Text="{Binding IconText}" FontSize="28" HorizontalAlignment="Center" VerticalAlignment="Center" />
              </Border>
              <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis" HorizontalAlignment="Center" />
            </StackPanel>
          </Border>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>
    <TextBlock Grid.Row="2" Text="{Binding ErrorText}" Margin="4" Foreground="OrangeRed" TextWrapping="Wrap"/>
  </Grid>
</UserControl>
