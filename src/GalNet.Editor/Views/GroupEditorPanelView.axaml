<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:GalNet.Editor.Controls"
             xmlns:vm="using:GalNet.Editor.ViewModels"
             x:Class="GalNet.Editor.Views.GroupEditorPanelView"
             x:DataType="vm:GroupEditorPanelViewModel"
             Background="{DynamicResource SemiColorBackground0}">
    <Grid RowDefinitions="Auto,*">
        <Border Grid.Row="0"
                Background="{DynamicResource SemiColorBackground1}"
                BorderBrush="{DynamicResource SemiColorBorder}"
                BorderThickness="0,0,0,1"
                Padding="8">
            <TextBlock Text="{Binding GroupNode.Name}"
                       FontWeight="SemiBold" />
        </Border>

        <controls:EntryListEditorControl Grid.Row="1"
                                         Margin="8" />
    </Grid>
</UserControl>
