<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:GalNet.Editor.ViewModels"
             xmlns:s="using:GalNet.Editor.Services"
             x:Class="GalNet.Editor.Views.LogPanelView"
             x:DataType="vm:LogPanelViewModel"
             Background="{DynamicResource SemiColorBackground0}">
    <Grid RowDefinitions="Auto,*">
        <StackPanel Orientation="Horizontal" Spacing="8" Margin="4,4,4,0">
            <ToggleButton IsChecked="{Binding OnlyShowErrors}"
                          ToolTip.Tip="Errors only"
                          AutomationProperties.Name="Errors only">
                <StackPanel Orientation="Horizontal" Spacing="4"><PathIcon Data="{StaticResource FilterIcon}" /><TextBlock Text="Errors Only" /></StackPanel>
            </ToggleButton>
            <ToggleButton IsChecked="{Binding AutoScroll}"
                          ToolTip.Tip="Auto-scroll"
                          AutomationProperties.Name="Auto-scroll">
                <StackPanel Orientation="Horizontal" Spacing="4"><PathIcon Data="{StaticResource ScrollIcon}" /><TextBlock Text="Auto-scroll" /></StackPanel>
            </ToggleButton>
        </StackPanel>

        <ListBox Name="LogListBox"
                 Grid.Row="1"
                 ItemsSource="{Binding Lines}"
                 Margin="4"
                 Background="Transparent">
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="s:LogLine">
                    <TextBlock Text="{Binding DisplayText}"
                               FontFamily="Consolas"
                               FontSize="12"
                               Foreground="{DynamicResource SemiColorText2}" />
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</UserControl>
