<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:globalization="clr-namespace:System.Globalization;assembly=System.Runtime"
             xmlns:loc="using:GalNet.Editor.MarkupExtensions"
             xmlns:vm="using:GalNet.Editor.ViewModels"
             x:Class="GalNet.Editor.Views.EditorSettingsPanelView"
             x:DataType="vm:EditorSettingsPanelViewModel"
             Background="{DynamicResource SemiColorBackground0}">
    <Grid RowDefinitions="Auto,*,Auto" Margin="12">
        <TextBlock Grid.Row="0" Text="{loc:Localize Settings.Editor.Title}"
                   FontSize="16" FontWeight="Bold"
                   Foreground="{DynamicResource SemiColorText0}"
                   Margin="0,0,0,12" />

        <ScrollViewer Grid.Row="1">
            <StackPanel Spacing="8">
                <TextBlock Text="{loc:Localize Settings.Theme}"
                           Foreground="{DynamicResource SemiColorText2}"
                           FontSize="12" />
                <ComboBox ItemsSource="{Binding AvailableThemes}"
                          SelectedItem="{Binding SelectedTheme, Mode=TwoWay}"
                          Foreground="{DynamicResource SemiColorText0}"
                          Background="{DynamicResource SemiColorBackground2}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:ThemeSelectionItem">
                            <TextBlock Text="{Binding DisplayName}"
                                       Foreground="{DynamicResource SemiColorText0}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <TextBlock Text="{loc:Localize Settings.UiLanguage}"
                           Foreground="{DynamicResource SemiColorText2}"
                           FontSize="12"
                           Margin="0,4,0,0" />
                <ComboBox ItemsSource="{Binding AvailableCultures}"
                          SelectedItem="{Binding SelectedCulture, Mode=TwoWay}"
                          Foreground="{DynamicResource SemiColorText0}"
                          Background="{DynamicResource SemiColorBackground2}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="globalization:CultureInfo">
                            <TextBlock Text="{Binding NativeName}"
                                       Foreground="{DynamicResource SemiColorText0}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Row="2" ColumnDefinitions="*,Auto" Margin="0,12,0,0">
            <TextBlock Grid.Column="0" Text="{Binding StatusText}"
                       Foreground="{DynamicResource SemiColorText2}"
                       VerticalAlignment="Center" />
            <Button Grid.Column="1" Content="{loc:Localize Settings.Save}"
                    Command="{Binding SaveSettingsCommand}"
                    Background="{DynamicResource SemiColorPrimary}"
                    Foreground="{DynamicResource SemiColorText0}"
                    Padding="16,8" />
        </Grid>
    </Grid>
</UserControl>
