<UserControl xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:loc="using:GalNet.Editor.MarkupExtensions" xmlns:vm="using:GalNet.Editor.ViewModels" x:Class="GalNet.Editor.Views.ExportPanelView" x:DataType="vm:ExportPanelViewModel" Background="{DynamicResource SemiColorBackground0}"><Grid RowDefinitions="Auto,Auto,Auto,*,Auto" Margin="16"><TextBlock Text="{loc:Localize Export.Title}" FontSize="16" FontWeight="Bold" /><TextBlock Grid.Row="1" Margin="0,14,0,4" Text="{loc:Localize Export.OutputDirectory}" Foreground="{DynamicResource SemiColorText2}" /><Grid Grid.Row="2" ColumnDefinitions="*,Auto" ColumnSpacing="8"><TextBox Text="{Binding OutputDirectory}" IsEnabled="{Binding !IsExporting}" /><Button Grid.Column="1" Content="{loc:Localize Export.Browse}" Command="{Binding BrowseCommand}" IsEnabled="{Binding !IsExporting}" /></Grid><StackPanel Grid.Row="3" Margin="0,12,0,0" Spacing="4"><TextBlock Text="{loc:Localize Export.Package}" Foreground="{DynamicResource SemiColorText2}" /><TextBlock Text="{Binding PackagePath}" TextWrapping="Wrap" /></StackPanel><Grid Grid.Row="4" ColumnDefinitions="*,Auto" Margin="0,14,0,0"><Button Grid.Column="1" Content="{loc:Localize Export.Action}" Click="OnExportClicked" IsEnabled="{Binding !IsExporting}" /></Grid></Grid></UserControl>
