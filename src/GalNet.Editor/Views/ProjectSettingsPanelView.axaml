<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:GalNet.Editor.ViewModels"
             x:Class="GalNet.Editor.Views.ProjectSettingsPanelView"
             x:DataType="vm:ProjectSettingsPanelViewModel"
             Background="{DynamicResource SemiColorBackground0}">
    <Grid RowDefinitions="Auto,*,Auto" Margin="12">
        <TextBlock Grid.Row="0" Text="项目设置"
                   FontSize="16" FontWeight="Bold"
                   Foreground="{DynamicResource SemiColorText0}"
                   Margin="0,0,0,12" />

        <ScrollViewer Grid.Row="1">
            <StackPanel Spacing="8">
                <TextBlock Text="默认分辨率"
                           Foreground="{DynamicResource SemiColorText2}"
                           FontSize="12" />
                <Grid ColumnDefinitions="*,Auto,*">
                    <NumericUpDown Grid.Column="0" Value="{Binding DefaultWidth}"
                                   Minimum="640" Maximum="7680" Increment="1"
                                   Foreground="{DynamicResource SemiColorText0}" />
                    <TextBlock Grid.Column="1" Text=" x " VerticalAlignment="Center"
                               Foreground="{DynamicResource SemiColorText3}"
                               Margin="4,0" />
                    <NumericUpDown Grid.Column="2" Value="{Binding DefaultHeight}"
                                   Minimum="480" Maximum="4320" Increment="1"
                                   Foreground="{DynamicResource SemiColorText0}" />
                </Grid>

                <TextBlock Text="存档槽位数"
                           Foreground="{DynamicResource SemiColorText2}"
                           FontSize="12"
                           Margin="0,4,0,0" />
                <NumericUpDown Value="{Binding SaveSlotCount}"
                               Minimum="1" Maximum="999" Increment="1"
                               Foreground="{DynamicResource SemiColorText0}" />

                <TextBlock Text="音效通道数"
                           Foreground="{DynamicResource SemiColorText2}"
                           FontSize="12"
                           Margin="0,4,0,0" />
                <NumericUpDown Value="{Binding SfxChannelCount}"
                               Minimum="1" Maximum="16" Increment="1"
                               Foreground="{DynamicResource SemiColorText0}" />

                <TextBlock Text="目标语言"
                           Foreground="{DynamicResource SemiColorText2}"
                           FontSize="12"
                           Margin="0,4,0,0" />
                <TextBox Text="{Binding TargetLocale}"
                         Foreground="{DynamicResource SemiColorText0}"
                         PlaceholderText="zh-CN" />
            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Row="2" ColumnDefinitions="*,Auto" Margin="0,12,0,0">
            <TextBlock Grid.Column="0" Text="{Binding IsDirtyText}"
                       Foreground="{DynamicResource SemiColorText2}"
                       VerticalAlignment="Center" />
            <Button Grid.Column="1" Content="保存设置"
                    Command="{Binding SaveSettingsCommand}"
                    Background="{DynamicResource SemiColorPrimary}"
                    Foreground="{DynamicResource SemiColorText0}"
                    Padding="16,8" />
        </Grid>
    </Grid>
</UserControl>
