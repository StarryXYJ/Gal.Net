<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="using:GalNet.Editor.MarkupExtensions"
             xmlns:vm="using:GalNet.Editor.ViewModels"
             x:Class="GalNet.Editor.Views.ProjectSettingsPanelView"
             x:DataType="vm:ProjectSettingsPanelViewModel"
             Background="{DynamicResource SemiColorBackground0}">
    <Grid RowDefinitions="Auto,*,Auto" Margin="12">
        <TextBlock Grid.Row="0" Text="{loc:Localize Settings.Project.Title}"
                   FontSize="16" FontWeight="Bold"
                   Foreground="{DynamicResource SemiColorText0}"
                   Margin="0,0,0,12" />

        <ScrollViewer Grid.Row="1">
            <StackPanel Spacing="8">
                <TextBlock Text="{loc:Localize Settings.Project.DefaultResolution}"
                           Foreground="{DynamicResource SemiColorText2}"
                           FontSize="12" />
                <ComboBox ItemsSource="{Binding ResolutionPresets}"
                          Text="{Binding Resolution}"
                          IsEditable="True"
                          Foreground="{DynamicResource SemiColorText0}" />

                <TextBlock Text="{loc:Localize Settings.Project.SaveSlotCount}"
                           Foreground="{DynamicResource SemiColorText2}"
                           FontSize="12"
                           Margin="0,4,0,0" />
                <NumericUpDown Value="{Binding SaveSlotCount}"
                               Minimum="1" Maximum="999" Increment="1"
                               Foreground="{DynamicResource SemiColorText0}" />

                <TextBlock Text="{loc:Localize Settings.Project.SfxChannelCount}"
                           Foreground="{DynamicResource SemiColorText2}"
                           FontSize="12"
                           Margin="0,4,0,0" />
                <NumericUpDown Value="{Binding SfxChannelCount}"
                               Minimum="1" Maximum="16" Increment="1"
                               Foreground="{DynamicResource SemiColorText0}" />

                <TextBlock Text="{loc:Localize Settings.Project.TargetLanguage}"
                           Foreground="{DynamicResource SemiColorText2}"
                           FontSize="12"
                           Margin="0,4,0,0" />
                <TextBox Text="{Binding TargetLocale}"
                         Foreground="{DynamicResource SemiColorText0}"
                         PlaceholderText="zh-CN" />
            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Row="2" ColumnDefinitions="*" Margin="0,12,0,0">
            <TextBlock Grid.Column="0" Text="{Binding IsDirtyText}"
                       Foreground="{DynamicResource SemiColorText2}"
                       VerticalAlignment="Center" />
        </Grid>
    </Grid>
</UserControl>
