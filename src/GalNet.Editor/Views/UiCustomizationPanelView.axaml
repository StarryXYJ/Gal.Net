<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:colorPicker="clr-namespace:Avalonia.Controls;assembly=Avalonia.Controls.ColorPicker"
             xmlns:loc="using:GalNet.Editor.MarkupExtensions"
             xmlns:vm="using:GalNet.Editor.ViewModels"
             x:Class="GalNet.Editor.Views.UiCustomizationPanelView"
             x:DataType="vm:UiCustomizationPanelViewModel"
             Background="{DynamicResource SemiColorBackground0}">
  <Grid Margin="12" RowDefinitions="*,Auto">
    <ScrollViewer Grid.Row="0" IsVisible="{Binding Configuration}"><StackPanel Spacing="14">
      <TextBlock Text="{loc:Localize UiCustomization.Title}" FontSize="16" FontWeight="SemiBold" />
      <TextBlock Text="{loc:Localize UiCustomization.Description}" TextWrapping="Wrap" Foreground="{DynamicResource SemiColorText2}" />
      <Expander Header="{loc:Localize UiCustomization.TitleScreen}" IsExpanded="True"><Grid Margin="4,10" ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="7">
        <TextBlock Text="{loc:Localize UiCustomization.Background}" /><colorPicker:ColorPicker Grid.Column="1" HorizontalAlignment="Right" Width="160" Color="{Binding Configuration.Title.BackgroundColor}" />
        <TextBlock Grid.Row="1" Text="{loc:Localize UiCustomization.TitleColor}" /><colorPicker:ColorPicker Grid.Row="1" Grid.Column="1" HorizontalAlignment="Right" Width="160" Color="{Binding Configuration.Title.TitleColor}" />
        <TextBlock Grid.Row="2" Text="{loc:Localize UiCustomization.TitleSize}" /><NumericUpDown Grid.Row="2" Grid.Column="1" HorizontalAlignment="Right" Width="120" Value="{Binding Configuration.Title.TitleFontSize}" Minimum="12" Maximum="160" />
        <TextBlock Grid.Row="3" Text="{loc:Localize UiCustomization.ButtonColor}" /><colorPicker:ColorPicker Grid.Row="3" Grid.Column="1" HorizontalAlignment="Right" Width="160" Color="{Binding Configuration.Title.ButtonColor}" />
        <TextBlock Grid.Row="4" Text="{loc:Localize UiCustomization.ButtonSize}" /><StackPanel Grid.Row="4" Grid.Column="1" HorizontalAlignment="Right" Orientation="Horizontal" Spacing="8"><NumericUpDown Value="{Binding Configuration.Title.ButtonWidth}" Minimum="80" Maximum="800" Width="100" /><NumericUpDown Value="{Binding Configuration.Title.ButtonHeight}" Minimum="24" Maximum="160" Width="100" /></StackPanel>
        <CheckBox Grid.Row="5" Grid.ColumnSpan="2" HorizontalAlignment="Right" Content="{loc:Localize UiCustomization.ShowGallery}" IsChecked="{Binding Configuration.Title.ShowGallery}" />
      </Grid></Expander>
      <Expander Header="{loc:Localize UiCustomization.GameScreen}" IsExpanded="True"><Grid Margin="4,10" ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="7">
        <TextBlock Text="{loc:Localize UiCustomization.DialogueBackground}" /><colorPicker:ColorPicker Grid.Column="1" HorizontalAlignment="Right" Width="160" Color="{Binding Configuration.Game.DialogueBackgroundColor}" />
        <TextBlock Grid.Row="1" Text="{loc:Localize UiCustomization.DialogueText}" /><colorPicker:ColorPicker Grid.Row="1" Grid.Column="1" HorizontalAlignment="Right" Width="160" Color="{Binding Configuration.Game.DialogueTextColor}" />
        <TextBlock Grid.Row="2" Text="{loc:Localize UiCustomization.SpeakerColor}" /><colorPicker:ColorPicker Grid.Row="2" Grid.Column="1" HorizontalAlignment="Right" Width="160" Color="{Binding Configuration.Game.SpeakerTextColor}" />
        <TextBlock Grid.Row="3" Text="{loc:Localize UiCustomization.DialogueHeight}" /><NumericUpDown Grid.Row="3" Grid.Column="1" HorizontalAlignment="Right" Width="120" Value="{Binding Configuration.Game.DialogueHeight}" Minimum="60" Maximum="600" />
        <TextBlock Grid.Row="4" Text="{loc:Localize UiCustomization.DialogueFontSize}" /><NumericUpDown Grid.Row="4" Grid.Column="1" HorizontalAlignment="Right" Width="120" Value="{Binding Configuration.Game.DialogueFontSize}" Minimum="10" Maximum="72" />
        <TextBlock Grid.Row="5" Text="{loc:Localize UiCustomization.ChoiceLayout}" /><TextBox Grid.Row="5" Grid.Column="1" HorizontalAlignment="Right" Width="180" Text="{Binding Configuration.Game.ChoiceLayout}" PlaceholderText="{loc:Localize UiCustomization.ChoiceLayoutHint}" />
        <TextBlock Grid.Row="6" Text="{loc:Localize UiCustomization.ChoiceButtonColor}" /><colorPicker:ColorPicker Grid.Row="6" Grid.Column="1" HorizontalAlignment="Right" Width="160" Color="{Binding Configuration.Game.ChoiceButtonColor}" />
        <TextBlock Grid.Row="7" Text="{loc:Localize UiCustomization.ChoiceButtonSize}" /><StackPanel Grid.Row="7" Grid.Column="1" HorizontalAlignment="Right" Orientation="Horizontal" Spacing="8"><NumericUpDown Value="{Binding Configuration.Game.ChoiceButtonWidth}" Minimum="80" Maximum="800" Width="100" /><NumericUpDown Value="{Binding Configuration.Game.ChoiceButtonHeight}" Minimum="24" Maximum="160" Width="100" /></StackPanel>
        <CheckBox Grid.Row="8" Grid.ColumnSpan="2" HorizontalAlignment="Right" Content="{loc:Localize UiCustomization.ShowCommandBar}" IsChecked="{Binding Configuration.Game.CommandBarVisible}" />
      </Grid></Expander>
      <Expander Header="{loc:Localize UiCustomization.StandardScreens}" IsExpanded="False"><Grid Margin="4,10" ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="7">
        <TextBlock Text="{loc:Localize UiCustomization.ScreenBackground}" /><colorPicker:ColorPicker Grid.Column="1" HorizontalAlignment="Right" Width="160" Color="{Binding Configuration.Settings.BackgroundColor}" />
        <TextBlock Grid.Row="1" Text="{loc:Localize UiCustomization.PanelColor}" /><colorPicker:ColorPicker Grid.Row="1" Grid.Column="1" HorizontalAlignment="Right" Width="160" Color="{Binding Configuration.Settings.PanelColor}" />
        <TextBlock Grid.Row="2" Text="{loc:Localize UiCustomization.TextColor}" /><colorPicker:ColorPicker Grid.Row="2" Grid.Column="1" HorizontalAlignment="Right" Width="160" Color="{Binding Configuration.Settings.TextColor}" />
      </Grid></Expander>
    </StackPanel></ScrollViewer>
    <Grid Grid.Row="1" Margin="0,10,0,0" ColumnDefinitions="*,Auto"><TextBlock Text="{Binding StatusText}" VerticalAlignment="Center" Foreground="{DynamicResource SemiColorText2}" TextWrapping="Wrap" /><Button Grid.Column="1" Content="{loc:Localize UiCustomization.SaveRefresh}" Command="{Binding ApplyCommand}" /></Grid>
  </Grid>
</UserControl>
