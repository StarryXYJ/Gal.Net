<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:colorPicker="clr-namespace:Avalonia.Controls;assembly=Avalonia.Controls.ColorPicker"
             xmlns:controls="clr-namespace:GalNet.Editor.Controls"
             xmlns:loc="using:GalNet.Editor.MarkupExtensions"
             xmlns:vm="using:GalNet.Editor.ViewModels"
             x:Class="GalNet.Editor.Views.UiCustomizationPanelView"
             x:DataType="vm:UiCustomizationPanelViewModel"
             Background="{DynamicResource SemiColorBackground0}">
  <Grid Margin="12" RowDefinitions="*,Auto">
    <ScrollViewer>
      <ItemsControl ItemsSource="{Binding Pages}">
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="vm:UiPageEditorViewModel">
            <Expander Header="{loc:Localize DisplayNameKey}" IsExpanded="True" Margin="0,0,0,10">
              <StackPanel Margin="4,10" Spacing="8">
                <TextBlock Text="{loc:Localize UiPreset.Preset}" FontWeight="SemiBold" />
                <ComboBox ItemsSource="{Binding Presets}" SelectedValue="{Binding SelectedPresetId, Mode=TwoWay}" SelectedValueBinding="{Binding Id}">
                  <ComboBox.ItemTemplate><DataTemplate><StackPanel><TextBlock Text="{loc:Localize DisplayNameKey}" /><TextBlock Text="{loc:Localize DescriptionKey}" FontSize="11" Opacity="0.65" /></StackPanel></DataTemplate></ComboBox.ItemTemplate>
                </ComboBox>
                <ItemsControl ItemsSource="{Binding Settings}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:UiSettingEditorViewModel">
                      <Grid ColumnDefinitions="180,*" ColumnSpacing="10" Margin="0,2">
                        <TextBlock Text="{loc:Localize DisplayNameKey}" VerticalAlignment="Center" />
                        <TextBox Grid.Column="1" Text="{Binding Value, Mode=TwoWay}" IsVisible="{Binding IsText}" />
                        <NumericUpDown Grid.Column="1" Value="{Binding IntegerValue, Mode=TwoWay}" Minimum="{Binding Minimum}" Maximum="{Binding Maximum}" Increment="1" FormatString="0" IsVisible="{Binding IsInteger}" />
                        <NumericUpDown Grid.Column="1" Value="{Binding FloatValue, Mode=TwoWay}" Minimum="{Binding Minimum}" Maximum="{Binding Maximum}" Increment="0.01" FormatString="0.##" IsVisible="{Binding IsFloat}" />
                        <colorPicker:ColorPicker Grid.Column="1" HorizontalAlignment="Left" Width="160" Color="{Binding ColorValue, Mode=TwoWay}" IsVisible="{Binding IsColor}" />
                        <controls:AssetPicker Grid.Column="1" HorizontalAlignment="Left" AssetManager="{Binding AssetManager}" Filter="{Binding AssetFilter}" SelectedAssetId="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsVisible="{Binding IsAsset}" />
                        <ComboBox Grid.Column="1" ItemsSource="{Binding Options}" SelectedValue="{Binding Value, Mode=TwoWay}" SelectedValueBinding="{Binding Value}" IsVisible="{Binding IsSelect}"><ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{loc:Localize DisplayNameKey}" /></DataTemplate></ComboBox.ItemTemplate></ComboBox>
                        <CheckBox Grid.Column="1" IsChecked="{Binding BooleanValue, Mode=TwoWay}" IsVisible="{Binding IsBoolean}" HorizontalAlignment="Left" />
                      </Grid>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </Expander>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>
    <Grid Grid.Row="1" Margin="0,10,0,0" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8"><TextBlock Text="{loc:Localize StatusKey}" VerticalAlignment="Center" TextWrapping="Wrap" Opacity="0.7" /><Button Grid.Column="1" Content="{loc:Localize UiCustomization.ResetPalette}" Click="OnResetPaletteClick" /><Button Grid.Column="2" Content="{loc:Localize UiCustomization.SaveRefresh}" Command="{Binding ApplyCommand}" /></Grid>
  </Grid>
</UserControl>
