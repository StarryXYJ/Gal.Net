<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:GalNet.Editor.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="560"
             x:Class="GalNet.Editor.Views.StartupPageView"
             x:DataType="vm:StartupPageViewModel"
             x:Name="Root">

    <Grid RowDefinitions="Auto,*,Auto" Background="{DynamicResource SemiColorBackground0}">
        <StackPanel Grid.Row="0" HorizontalAlignment="Left" Margin="10,10,0,40">
            <TextBlock Text="GalNet Editor"
                       FontSize="36" FontWeight="Bold"
                       Foreground="{DynamicResource SemiColorText0}"
                       HorizontalAlignment="Center" />
        </StackPanel>

        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled">
            <StackPanel VerticalAlignment="Top" HorizontalAlignment="Center" Spacing="16" Margin="0,0,0,32">
                <Button Content="  新建项目"
                        Command="{Binding NewProjectCommand}"
                        Width="260" Height="48"
                        Background="{DynamicResource SemiColorPrimary}"
                        Foreground="{DynamicResource SemiColorText0}"
                        FontSize="16" FontWeight="SemiBold"
                        CornerRadius="6" />

                <Button Content="  打开项目"
                        Command="{Binding OpenProjectCommand}"
                        Width="260" Height="48"
                        Background="{DynamicResource SemiColorBackground3}"
                        Foreground="{DynamicResource SemiColorText0}"
                        FontSize="16" FontWeight="SemiBold"
                        CornerRadius="6" />

                <Separator Margin="0,12"
                           Background="{DynamicResource SemiColorBorder}"
                           Height="1"
                           Width="260" />

                <TextBlock Text="最近项目"
                           FontSize="13"
                           Foreground="{DynamicResource SemiColorText3}"
                           HorizontalAlignment="Center"
                           Margin="0,4,0,0" />

                <ItemsControl ItemsSource="{Binding RecentProjects}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Spacing="6" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:RecentProjectItem">
                            <Border Background="{DynamicResource SemiColorBackground2}"
                                    BorderBrush="{DynamicResource SemiColorBorder}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="12,10"
                                    Width="260">
                                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                                    <TextBlock Grid.Row="0" Grid.Column="0"
                                               Text="{Binding Name}"
                                               FontSize="14" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SemiColorText0}" />
                                    <Button Grid.Row="0" Grid.Column="1" Grid.RowSpan="2"
                                            Content="打开"
                                            Command="{Binding ElementName=Root, Path=DataContext.OpenRecentProjectCommand}"
                                            CommandParameter="{Binding}"
                                            Background="Transparent"
                                            Foreground="{DynamicResource SemiColorLink}"
                                            FontSize="12"
                                            Margin="8,0,0,0"
                                            Padding="8,4" />

                                    <TextBlock Grid.Row="1" Grid.Column="0"
                                               Text="{Binding Path}"
                                               FontSize="11"
                                               Foreground="{DynamicResource SemiColorText3}"
                                               TextTrimming="CharacterEllipsis" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2"
                Background="{DynamicResource SemiColorBackground1}"
                Padding="12,8">
            <TextBlock Text="GalNet Editor v0.1 - Phase 3.2 MVP"
                       FontSize="11"
                       Foreground="{DynamicResource SemiColorText3}"
                       HorizontalAlignment="Center" />
        </Border>
    </Grid>
</UserControl>
