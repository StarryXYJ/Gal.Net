<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:GalNet.Editor.ViewModels"
             x:Class="GalNet.Editor.Views.GamePreviewPanelView"
             x:DataType="vm:GamePreviewPanelViewModel"
             MinHeight="300"
             MinWidth="300"
             Background="{DynamicResource SemiColorBackground0}">
    <Grid RowDefinitions="Auto,*" Margin="4">
        <Border Grid.Row="0"
                Background="{DynamicResource SemiColorBackground1}"
                BorderBrush="{DynamicResource SemiColorBorder}"
                BorderThickness="0,0,0,1"
                Padding="8,6">
            <Grid ColumnDefinitions="Auto,Auto,*,Auto">
                <Button Content="Restart"
                        Command="{Binding RestartPreviewCommand}" />
                <Button Grid.Column="1"
                        Margin="8,0,0,0"
                        Content="Reset Player"
                        Click="OnResetPlayerClick" />
                <TextBlock Grid.Column="2"
                           Text="{Binding StatusText}"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource SemiColorText2}" />
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Background="{DynamicResource SemiColorBackground1}"
                BorderBrush="{DynamicResource SemiColorBorder}"
                BorderThickness="1"
                CornerRadius="4"
                Margin="4,2"
                ClipToBounds="True">
            <ContentControl Name="GameViewHost"
                            HorizontalContentAlignment="Stretch"
                            VerticalContentAlignment="Stretch" />
        </Border>
    </Grid>
</UserControl>
