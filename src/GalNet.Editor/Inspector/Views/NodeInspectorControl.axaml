<UserControl xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:GalNet.Editor.Controls" xmlns:vm="using:GalNet.Editor.Inspector.ViewModels" xmlns:loc="using:GalNet.Editor.MarkupExtensions"
             x:Class="GalNet.Editor.Inspector.Views.NodeInspectorControl" x:DataType="vm:NodeInspectorControlViewModel">
  <ScrollViewer><StackPanel Margin="12" Spacing="10">

    <TextBlock Text="{loc:Localize Inspector.Node.NoSelection}" Foreground="{DynamicResource SemiColorText2}" IsVisible="{Binding !HasSelectedNode}" />
    <StackPanel Spacing="8" IsVisible="{Binding HasSelectedNode}">
      <TextBlock Text="{loc:Localize Inspector.Node.Name}" /><TextBox Text="{Binding Workspace.SelectedNode.Name}" />
      <TextBlock Text="{loc:Localize Inspector.Node.Type}" /><Border Background="{DynamicResource SemiColorFill0}" BorderBrush="{DynamicResource SemiColorBorder}" BorderThickness="1" CornerRadius="4" Padding="8,5"><TextBlock Text="{Binding Workspace.SelectedNode.KindLabel}" Foreground="{DynamicResource SemiColorText1}" TextTrimming="CharacterEllipsis" /></Border>
      <TextBlock Text="{loc:Localize Inspector.Node.Id}" /><Border Background="{DynamicResource SemiColorFill0}" BorderBrush="{DynamicResource SemiColorBorder}" BorderThickness="1" CornerRadius="4" Padding="8,5"><TextBlock Text="{Binding Workspace.SelectedNode.Id}" FontFamily="Consolas" FontSize="12" Foreground="{DynamicResource SemiColorText2}" TextTrimming="CharacterEllipsis" /></Border>
      <StackPanel Spacing="6" IsVisible="{Binding IsLinearGroupSelected}"><TextBlock Text="{loc:Localize Inspector.Node.LinearGroup}" FontWeight="SemiBold" /><TextBlock Text="{Binding EntryCountText}" Foreground="{DynamicResource SemiColorText2}" /><Button Content="{loc:Localize Inspector.Node.OpenGroupEditor}" HorizontalAlignment="Left" Command="{Binding OpenGroupEditorCommand}" /></StackPanel>
      <StackPanel Spacing="6" IsVisible="{Binding IsChoiceBranchSelected}"><TextBlock Text="{loc:Localize Inspector.Node.Options}" FontWeight="SemiBold" /><controls:BranchOptionListEditorControl ItemsSource="{Binding Workspace.SelectedNode.Options}" AddCommand="{Binding Workspace.AddChoiceOptionCommand}" RemoveCommand="{Binding Workspace.RemoveChoiceOptionCommand}" MoveCommand="{Binding Workspace.ReorderChoiceOptionCommand}" ConditionSuggestions="{Binding ConditionSuggestions}" ValidationVariables="{Binding ValidationVariables}" /></StackPanel>
      <StackPanel Spacing="6" IsVisible="{Binding IsConditionBranchSelected}"><TextBlock Text="{loc:Localize Inspector.Node.Conditions}" FontWeight="SemiBold" /><controls:BranchConditionListEditorControl ItemsSource="{Binding Workspace.SelectedNode.Conditions}" AddCommand="{Binding Workspace.AddConditionCommand}" RemoveCommand="{Binding Workspace.RemoveConditionCommand}" MoveCommand="{Binding Workspace.ReorderConditionCommand}" ConditionSuggestions="{Binding ConditionSuggestions}" ValidationVariables="{Binding ValidationVariables}" /></StackPanel>
    </StackPanel>
  </StackPanel></ScrollViewer>
</UserControl>
