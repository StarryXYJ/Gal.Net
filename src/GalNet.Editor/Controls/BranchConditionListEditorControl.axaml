<controls:ReorderableListControl xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:controls="using:GalNet.Editor.Controls" xmlns:vm="using:GalNet.Editor.ViewModels" x:Class="GalNet.Editor.Controls.BranchConditionListEditorControl" x:Name="Root" PointerMoved="OnDragPointerMoved" PointerReleased="OnDragPointerReleased">
  <Grid RowDefinitions="Auto,*">
    <Button HorizontalAlignment="Left" Command="{Binding AddCommand, ElementName=Root}">
      <PathIcon Width="16" Height="16" Data="{StaticResource AddIcon}" />
    </Button>
    <ListBox x:Name="ItemsListBox" Grid.Row="1" ItemsSource="{Binding ItemsSource, ElementName=Root}" Background="Transparent"><ListBox.ItemTemplate><DataTemplate x:DataType="vm:BranchConditionEditorItemViewModel"><Border Margin="0,4" Padding="8" Background="{DynamicResource SemiColorBackground1}" BorderBrush="{DynamicResource SemiColorBorder}" BorderThickness="1" CornerRadius="6"><Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="6"><Border Padding="6,0" VerticalAlignment="Center" Background="Transparent" Cursor="SizeAll" PointerPressed="OnDragHandlePressed"><TextBlock Text="::" /></Border><controls:ConditionEditorControl Grid.Column="1" Text="{Binding Expression}" Suggestions="{Binding ConditionSuggestions, ElementName=Root}" ValidationVariables="{Binding ValidationVariables, ElementName=Root}" /><Button Grid.Column="2" Command="{Binding RemoveCommand, ElementName=Root}" CommandParameter="{Binding}"><PathIcon Width="16" Height="16" Data="{StaticResource DeleteRegularIcon}" /></Button></Grid></Border></DataTemplate></ListBox.ItemTemplate></ListBox>
  </Grid>
</controls:ReorderableListControl>
