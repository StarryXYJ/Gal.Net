<controls:ReorderableListControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:GalNet.Editor.Controls"
             xmlns:vm="using:GalNet.Editor.ViewModels"
             x:Class="GalNet.Editor.Controls.EntryListEditorControl"
             x:Name="Root"
             x:DataType="vm:GroupEditorPanelViewModel"
             MoveCommand="{Binding ReorderEntryCommand}"
             PointerMoved="OnDragPointerMoved"
             PointerReleased="OnDragPointerReleased">
    <Grid RowDefinitions="Auto,*">
        <Button HorizontalAlignment="Left"
                ToolTip.Tip="Add entry"
                AutomationProperties.Name="Add entry"
                Command="{Binding AddEntryCommand}"><PathIcon Width="16" Height="16" Data="{StaticResource AddIcon}" /></Button>

        <ListBox Name="ItemsListBox"
                 Grid.Row="1"
                 Margin="0,8,0,0"
                 ItemsSource="{Binding GroupNode.Entries}"
                 Background="Transparent">
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="vm:EntryEditorItemViewModel">
                    <Border Margin="0,4"
                            Padding="8"
                            Background="{DynamicResource SemiColorBackground1}"
                            BorderBrush="{DynamicResource SemiColorBorder}"
                            BorderThickness="1"
                            CornerRadius="6">
                        <Grid ColumnDefinitions="Auto,48,140,*,*,Auto"
                              ColumnSpacing="8">
                            <Border Padding="6,0"
                                    VerticalAlignment="Center"
                                    Background="Transparent"
                                    Cursor="SizeAll"
                                    PointerPressed="OnDragHandlePressed">
                                <TextBlock Text="::" />
                            </Border>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding Id}"
                                       VerticalAlignment="Center" />
                            <TextBox Grid.Column="2"
                                     Text="{Binding Type}" />
                            <controls:ConditionEditorControl Grid.Column="3"
                                                             Text="{Binding Condition}"
                                                             Suggestions="{Binding #Root.DataContext.ConditionSuggestions}"
                                                             ValidationVariables="{Binding #Root.DataContext.ValidationVariables}" />
                            <TextBox Grid.Column="4"
                                     Text="{Binding Parameters}" />
                            <Button Grid.Column="5"
                                    ToolTip.Tip="Remove entry"
                                    AutomationProperties.Name="Remove entry"
                                    Command="{Binding #Root.DataContext.RemoveEntryCommand}"
                                    CommandParameter="{Binding}"><PathIcon Width="16" Height="16" Data="{StaticResource DeleteRegularIcon}" /></Button>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</controls:ReorderableListControl>
