<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:models="using:GalNet.Editor.Models"
             xmlns:local="using:GalNet.Editor.Controls"
             mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="40"
             x:Class="GalNet.Editor.Controls.SideMenu"
             x:Name="Root">

    <Menu ItemsSource="{Binding ItemsSource, ElementName=Root}"
          FontSize="13">
        <Menu.Styles>
            <!-- 将 MenuData.IsSeparator 映射到附加属性，供样式选择器匹配 -->
            <!-- 附加属性用 ReflectionBinding 避免编译绑定语法限制 -->
            <Style Selector="MenuItem">
                <Setter Property="(local:MenuEntry.IsSeparator)" Value="{ReflectionBinding IsSeparator}" />
                <Setter Property="Command" Value="{Binding Command}" x:DataType="models:MenuData" />
                <Setter Property="CommandParameter" Value="{Binding CommandParameter}" x:DataType="models:MenuData" />
                <Setter Property="InputGesture" Value="{Binding InputGesture}" x:DataType="models:MenuData" />
                <Setter Property="IsEnabled" Value="{Binding IsEnabled}" x:DataType="models:MenuData" />
            </Style>

            <!-- 顶级分隔符 — 显示为竖线，无交互 -->
            <Style Selector="Menu > MenuItem[(local|MenuEntry.IsSeparator)=True]">
                <Setter Property="Template">
                    <ControlTemplate>
                        <Rectangle Width="2"
                                   Fill="{DynamicResource SemiGrey3}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Stretch"
                                   Margin="4,2" />
                    </ControlTemplate>
                </Setter>
                <Setter Property="IsHitTestVisible" Value="False" />
                <Setter Property="Focusable" Value="False" />
                <Setter Property="IsEnabled" Value="False" />
                <Setter Property="Height" Value="20" />
                <Setter Property="Width" Value="10" />
            </Style>

            <!-- 子菜单分隔符 — 显示为横向线条，无交互 -->
            <Style Selector="MenuItem MenuItem[(local|MenuEntry.IsSeparator)=True]">
                <Setter Property="Template">
                    <ControlTemplate>
                        <Separator Margin="8,4"
                                   Background="{DynamicResource SemiGrey3}"
                                   Height="1" />
                    </ControlTemplate>
                </Setter>
                <Setter Property="IsHitTestVisible" Value="False" />
                <Setter Property="Focusable" Value="False" />
                <Setter Property="IsEnabled" Value="False" />
                <Setter Property="Height" Value="9" />
            </Style>
        </Menu.Styles>

        <Menu.ItemTemplate>
            <TreeDataTemplate DataType="models:MenuData"
                              ItemsSource="{Binding Children}">
                <TextBlock x:DataType="models:MenuData"
                           Text="{Binding Header}"
                           Margin="4,0" />
            </TreeDataTemplate>
        </Menu.ItemTemplate>
    </Menu>
</UserControl>
