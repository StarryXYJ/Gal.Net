<UserControl xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:ui="clr-namespace:GalNet.Control.Abstraction.UI;assembly=GalNet.Control.Abstraction" xmlns:vm="clr-namespace:GalNet.Control.Widget" x:Class="GalNet.Control.Widget.BuiltIn.DefaultChoiceTemplate" x:DataType="vm:ChoicePanelWidgetViewModel">
  <ItemsControl ItemsSource="{Binding Options}" Tag="{Binding SelectCommand}" HorizontalAlignment="Center" VerticalAlignment="Center">
    <ItemsControl.ItemsPanel><ItemsPanelTemplate><StackPanel Spacing="8"/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
    <ItemsControl.DataTemplates><DataTemplate x:DataType="x:String"><Button Content="{Binding}" Command="{Binding $parent[ItemsControl].Tag}" CommandParameter="{Binding}" MinWidth="200" MinHeight="40" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Background="{ui:PaletteBrush Background1}" Foreground="{ui:PaletteBrush FontColor0}"/></DataTemplate></ItemsControl.DataTemplates>
  </ItemsControl>
</UserControl>
