<UserControl xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:ui="clr-namespace:GalNet.Control.Abstraction.UI;assembly=GalNet.Control.Abstraction" xmlns:vm="clr-namespace:GalNet.Control.Widget" x:Class="GalNet.Control.Widget.BuiltIn.DefaultToggleTemplate" x:DataType="vm:ToggleWidgetViewModel">
  <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center"><CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay}" Foreground="{ui:PaletteBrush PrimaryColor}"/><TextBlock Text="{Binding Label}" VerticalAlignment="Center" Foreground="{ui:PaletteBrush FontColor0}"/></StackPanel>
</UserControl>
