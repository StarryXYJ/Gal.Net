<UserControl xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" 
             xmlns:ui="clr-namespace:GalNet.Control.Abstraction.UI;assembly=GalNet.Control.Abstraction" 
             xmlns:vm="clr-namespace:GalNet.Control.Widget" 
             x:Class="GalNet.Control.Widget.BuiltIn.DefaultSlotTemplate" 
             x:DataType="vm:SaveSlotWidgetViewModel">
  <Button Command="{Binding Command}"
          IsEnabled="{Binding IsEnabled}" 
          Padding="12" CornerRadius="6" 
          HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch" 
          Background="{ui:PaletteBrush Background1}" BorderBrush="{ui:PaletteBrush BorderColor}"
          BorderThickness="1">
    <StackPanel Spacing="4">
      <TextBlock Text="{Binding Title}" FontWeight="Bold" 
                 Foreground="{ui:PaletteBrush FontColor0}"/>
      <TextBlock Text="{Binding Description}" TextWrapping="Wrap"
                 Foreground="{ui:PaletteBrush FontColor1}"/>
    </StackPanel>
  </Button>
</UserControl>
