<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="960" d:DesignHeight="600"
             x:Class="GalNet.Control.Screen.BuiltIn.TitleScreenView"
             Background="#CC0A0A1E">

    <UserControl.Styles>
        <Style Selector="Button.TitleMenuBtn">
            <Setter Property="FontSize" Value="20" />
            <Setter Property="Width" Value="260" />
            <Setter Property="Height" Value="50" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#334" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Margin" Value="0,6" />
        </Style>
    </UserControl.Styles>

    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="40">
        <TextBlock Name="TitleBlock"
                   FontSize="48" FontWeight="Bold"
                   Foreground="White"
                   HorizontalAlignment="Center" />

        <StackPanel Name="ButtonPanel"
                    Orientation="Vertical"
                    HorizontalAlignment="Center"
                    Spacing="12" />
    </StackPanel>

</UserControl>
