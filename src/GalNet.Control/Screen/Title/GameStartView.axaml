<UserControl xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:GalNet.Control.ViewModels" x:Class="GalNet.Control.Views.GameStartView" x:DataType="vm:GameStartViewModel">
  <Grid>
    <Border Background="{Binding BackgroundBrush}" />
    <Image Source="{Binding BackgroundImageSource}" Stretch="{Binding BackgroundStretch}" IsVisible="{Binding HasBackgroundImage}" />
    <Grid.Resources>
      <ControlTheme x:Key="TitleButtonTheme" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Background" Value="{Binding MenuItemBackgroundBrush}" /><Setter Property="Foreground" Value="{Binding MenuTextBrush}" />
        <Setter Property="FontSize" Value="{Binding Configuration.MenuFontSize}" /><Setter Property="HorizontalContentAlignment" Value="{Binding MenuHorizontalAlignment}" />
        <Style Selector="^:pointerover"><Setter Property="Background" Value="{Binding MenuItemHoverBackgroundBrush}" /><Setter Property="Foreground" Value="{Binding MenuHoverTextBrush}" /></Style>
      </ControlTheme>
    </Grid.Resources>
    <StackPanel VerticalAlignment="Center" HorizontalAlignment="{Binding MenuHorizontalAlignment}" Margin="{Binding ContentMargin}" Spacing="{Binding Configuration.MenuSpacing}">
      <TextBlock Text="{Binding Title}" FontSize="{Binding Configuration.TitleFontSize}" Foreground="{Binding TitleBrush}" HorizontalAlignment="{Binding MenuHorizontalAlignment}" TextWrapping="Wrap" TextAlignment="{Binding MenuTextAlignment}" Margin="{Binding TitleMenuMargin}" />
      <Button HorizontalAlignment="{Binding MenuHorizontalAlignment}" Theme="{StaticResource TitleButtonTheme}" Content="New Game" Command="{Binding NewGameCommand}" Width="{Binding Configuration.ButtonWidth}" Height="{Binding Configuration.ButtonHeight}" />
      <Button HorizontalAlignment="{Binding MenuHorizontalAlignment}" Theme="{StaticResource TitleButtonTheme}" Content="Continue" Command="{Binding ContinueCommand}" IsVisible="{Binding IsContinueVisible}" Width="{Binding Configuration.ButtonWidth}" Height="{Binding Configuration.ButtonHeight}" />
      <Button HorizontalAlignment="{Binding MenuHorizontalAlignment}" Theme="{StaticResource TitleButtonTheme}" Content="Load" Command="{Binding LoadCommand}" Width="{Binding Configuration.ButtonWidth}" Height="{Binding Configuration.ButtonHeight}" />
      <Button HorizontalAlignment="{Binding MenuHorizontalAlignment}" Theme="{StaticResource TitleButtonTheme}" Content="Gallery" Command="{Binding GalleryCommand}" IsVisible="{Binding ShowGallery}" Width="{Binding Configuration.ButtonWidth}" Height="{Binding Configuration.ButtonHeight}" />
      <Button HorizontalAlignment="{Binding MenuHorizontalAlignment}" Theme="{StaticResource TitleButtonTheme}" Content="Settings" Command="{Binding SettingsCommand}" Width="{Binding Configuration.ButtonWidth}" Height="{Binding Configuration.ButtonHeight}" />
      <Button HorizontalAlignment="{Binding MenuHorizontalAlignment}" Theme="{StaticResource TitleButtonTheme}" Content="Quit" Command="{Binding QuitCommand}" Width="{Binding Configuration.ButtonWidth}" Height="{Binding Configuration.ButtonHeight}" />
    </StackPanel>
  </Grid>
</UserControl>
