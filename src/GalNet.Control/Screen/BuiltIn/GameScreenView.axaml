<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vlc="clr-namespace:LibVLCSharp.Avalonia;assembly=LibVLCSharp.Avalonia"
             mc:Ignorable="d" d:DesignWidth="960" d:DesignHeight="600"
             x:Class="GalNet.Control.Screen.BuiltIn.GameScreenView"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch"
             Background="#111118">

    <UserControl.Styles>
        <Style Selector="Button.CommandBarItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="Padding" Value="4,2" />
        </Style>
        <Style Selector="ToggleButton.CommandBarItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="Padding" Value="4,2" />
        </Style>
        <Style Selector="ToggleButton.CommandBarItem:pointerover">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#8ED8FF" />
        </Style>
        <Style Selector="ToggleButton.CommandBarItem:pressed">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#FFC857" />
        </Style>
        <Style Selector="ToggleButton.CommandBarItem:checked">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#FFC857" />
        </Style>
        <Style Selector="Button.CommandBarItem:pointerover">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="TextBlock.TextDecorations" Value="Underline" />
        </Style>
        <Style Selector="Button.CommandBarItem:pressed">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#FFC857" />
        </Style>
    </UserControl.Styles>

    <Grid>
        <!-- Image/background layer canvas (bottom) -->
        <Canvas Name="LayerCanvas" ClipToBounds="True" />

        <!-- Video layer (above image canvas, below dialog) -->
        <vlc:VideoView Name="VideoView"
                       IsVisible="False"
                       HorizontalAlignment="Stretch"
                       VerticalAlignment="Stretch" />

        <!-- Dialogue host -->
        <ContentControl Name="DialogueHost"
                        IsVisible="False"
                        VerticalAlignment="Bottom" />

        <!-- Choice panel host (centered over dialogue) -->
        <ContentControl Name="ChoiceHost"
                        IsVisible="False"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center" />

        <!-- Screen overlay (top layer, covers everything) -->
        <ContentControl Name="ScreenOverlay"
                        IsVisible="False" />

        <!-- Click-to-continue indicator (bottom-right) -->
        <TextBlock Name="ClickIndicator"
                   Text="&#x25BC;"
                   FontSize="14"
                   Foreground="White"
                   IsVisible="False"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Bottom"
                   Margin="0,0,20,10" />

        <!-- Built-in game command bar. It is deliberately outside the dialogue widget system. -->
        <StackPanel Name="CommandBar" Orientation="Horizontal" Spacing="10"
                    HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,12">
            <ToggleButton Classes="CommandBarItem" Name="AutoButton" Content="Auto" />
            <ToggleButton Classes="CommandBarItem" Name="QuickButton" Content="Quick" />
            <Button Classes="CommandBarItem" Name="SaveButton" Content="Save" />
            <Button Classes="CommandBarItem" Name="LoadButton" Content="Load" />
            <Button Classes="CommandBarItem" Name="SettingsButton" Content="Settings" />
            <Button Classes="CommandBarItem" Name="MenuButton" Content="Menu" />
            <Button Classes="CommandBarItem" Name="ScreenshotButton" Content="Screenshot" />
            <Button Classes="CommandBarItem" Name="HideButton" Content="×" />
        </StackPanel>
    </Grid>

</UserControl>
