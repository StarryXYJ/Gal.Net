<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="960" d:DesignHeight="600"
             x:Class="GalNet.Control.Screen.BuiltIn.SettingsScreenView"
             Background="#CC141428">

    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="20">
        <TextBlock Name="TitleBlock"
                   Text="Settings"
                   FontSize="32" FontWeight="Bold"
                   Foreground="White"
                   HorizontalAlignment="Center" />

        <StackPanel Name="SettingsPanel"
                    Orientation="Vertical"
                    HorizontalAlignment="Center"
                    Spacing="14" />

        <Button Name="BackButton"
                Content="Back"
                FontSize="16"
                Width="160" Height="40"
                HorizontalAlignment="Center"
                Margin="0,20,0,0" />
    </StackPanel>

</UserControl>
