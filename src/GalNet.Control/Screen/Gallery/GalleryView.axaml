<UserControl xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:vm="clr-namespace:GalNet.Control.ViewModels" x:Class="GalNet.Control.Views.GalleryView" x:DataType="vm:GalleryViewModel">
  <UserControl.Resources><ResourceDictionary><ResourceDictionary.MergedDictionaries><ResourceInclude Source="avares://GalNet.Control/Assets/Icons.axaml" /></ResourceDictionary.MergedDictionaries></ResourceDictionary></UserControl.Resources>
  <Grid Background="{Binding Configuration.BackgroundColor}"><Border Margin="48" Padding="28" Background="#66171924" BorderBrush="#665F6075" BorderThickness="1" CornerRadius="14">
    <Grid RowDefinitions="Auto,*" RowSpacing="18"><TextBlock Text="Gallery" FontSize="28" FontWeight="SemiBold" Foreground="{Binding Configuration.TextColor}"/><Button Command="{Binding BackCommand}" HorizontalAlignment="Right" VerticalAlignment="Top" ToolTip.Tip="Back"><PathIcon Width="18" Height="18" Data="{StaticResource BackwardRegular}" /></Button><ScrollViewer Grid.Row="1"><ItemsControl ItemsSource="{Binding Items}"><ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel><ItemsControl.ItemTemplate><DataTemplate x:DataType="vm:GalleryItemViewModel"><Button Content="{Binding Title}" Command="{Binding OpenCommand}" Width="190" Height="118" Margin="6"/></DataTemplate></ItemsControl.ItemTemplate></ItemsControl></ScrollViewer></Grid>
  </Border></Grid>
</UserControl>
