<UserControl xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:ui="clr-namespace:GalNet.Control.Abstraction.UI;assembly=GalNet.Control.Abstraction" xmlns:vm="clr-namespace:GalNet.Control.ViewModels" xmlns:host="clr-namespace:GalNet.Control.UI" x:Class="GalNet.Control.Views.GalleryView" x:DataType="vm:GalleryViewModel" Background="{ui:PaletteBrush Background0}">
  <UserControl.DataTemplates><DataTemplate DataType="host:WidgetHostViewModel" x:DataType="host:WidgetHostViewModel"><ContentControl Content="{Binding View}"/></DataTemplate></UserControl.DataTemplates>
  <Grid ColumnDefinitions="160,*" Margin="36" ColumnSpacing="24">
    <ItemsControl ItemsSource="{Binding CategoryHosts}" IsVisible="{Binding ShowCategorySelector}"><ItemsControl.ItemsPanel><ItemsPanelTemplate><StackPanel Spacing="8"/></ItemsPanelTemplate></ItemsControl.ItemsPanel></ItemsControl>
    <StackPanel Grid.Column="1" Spacing="16"><TextBlock Text="Gallery" FontSize="32" FontWeight="SemiBold"/><ScrollViewer HorizontalScrollBarVisibility="Disabled"><ItemsControl ItemsSource="{Binding ItemHosts}"><ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel></ItemsControl></ScrollViewer><ContentControl Content="{Binding BackButtonHost.View}" HorizontalAlignment="Left"/></StackPanel>
  </Grid>
</UserControl>
