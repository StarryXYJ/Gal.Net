<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="960" d:DesignHeight="600"
             x:Class="GalNet.Control.Host.GameHostView"
             Background="#111">

    <Grid>
        <!-- Main navigation content -->
        <ContentControl Name="MainContent"
                        HorizontalContentAlignment="Stretch"
                        VerticalContentAlignment="Stretch" />

        <!-- Modal overlay (transient) -->
        <ContentControl Name="ModalOverlay" IsVisible="False" />

        <!-- Toast overlay -->
        <Border Name="ToastBar"
                IsVisible="False"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Margin="0,0,0,40"
                Padding="16,8"
                CornerRadius="4"
                Background="#CC333333">
            <TextBlock Name="ToastText" Foreground="White" FontSize="14" />
        </Border>
    </Grid>

</UserControl>
